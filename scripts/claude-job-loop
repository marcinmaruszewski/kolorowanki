#!/usr/bin/env bash

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROMPT_FILE="$ROOT/JOB.md"
PROGRESS_FILE="${PROGRESS_FILE:-}"
DELAY_SECONDS="${DELAY_SECONDS:-0}"
MAX_RUNS="${MAX_RUNS:-0}"
CONTINUE_ON_ERROR="${CONTINUE_ON_ERROR:-0}"
WAIT_ON_LIMIT="${WAIT_ON_LIMIT:-1}"
WAIT_FALLBACK_SECONDS="${WAIT_FALLBACK_SECONDS:-900}"
WAIT_BUFFER_SECONDS="${WAIT_BUFFER_SECONDS:-60}"
COMPLETION_PROMISE="${COMPLETION_PROMISE:-COMPLETE}"
PERMISSION_MODE="${PERMISSION_MODE:-acceptEdits}"
OUTPUT_FORMAT="${OUTPUT_FORMAT:-stream-json}"
LOG_DIR="${LOG_DIR:-$ROOT/.logs/claude-job-loop}"
LOG_FILE="${LOG_FILE:-}"
PROGRESS_FILE_DISABLED=0

usage() {
  cat <<'EOF'
Użycie:
  ./scripts/claude-job-loop [--prompt PLIK] [--delay SEKUNDY] [--max-runs N]
                            [--continue-on-error] [--no-wait-on-limit]
                            [--wait-fallback SEKUNDY] [--wait-buffer SEKUNDY]
                            [--log-dir KATALOG] [--log-file PLIK]
                            [--progress-file PLIK] [--no-progress-file]
                            [--completion-promise TEKST]
                            [--permission-mode TRYB]
                            [--output-format text|json|stream-json]
  ./scripts/claude-job-loop [--help]

Opis:
  W pętli uruchamia świeże `claude -p` w stylu Ralph Loop.
  Po każdej iteracji ponownie wczytuje plik promptu i opcjonalny plik postępu,
  więc zmiany w `JOB.md` i progressie są brane pod uwagę bez restartu skryptu.

  Gdy Claude zwróci komunikat o wyczerpaniu limitu i poda czas resetu,
  skrypt może poczekać do resetu i ponowić próbę. `--max-runs` liczy tylko
  udane przebiegi, więc limit nie zjada dostępnych iteracji.

  Domyślnie skrypt:
  - używa `--permission-mode acceptEdits`
  - zapisuje postęp w `./.logs/claude-job-loop/progress.txt`
  - oczekuje completion sigila `<promise>COMPLETE</promise>`
  - streamuje output przez `--output-format stream-json --verbose`
  - fail-fastuje, gdy Claude poprosi o zgodę zamiast działać autonomicznie

Opcje:
  --prompt PLIK           Plik z promptem. Domyślnie: ./JOB.md
  --delay SEKUNDY         Pauza między udanymi uruchomieniami. Domyślnie: 0
  --max-runs N            Maksymalna liczba udanych iteracji. 0 = bez limitu
  --continue-on-error     Nie przerywaj pętli po zwykłym błędzie komendy
  --no-wait-on-limit      Wyłącz automatyczne czekanie na reset limitu
  --wait-fallback N       Awaryjny czas czekania, gdy nie da się sparsować resetu
  --wait-buffer N         Bufor dodawany do czasu resetu. Domyślnie: 60
  --log-dir KATALOG       Katalog logów. Domyślnie: ./.logs/claude-job-loop
  --log-file PLIK         Konkretny plik logu. Domyślnie: timestamp w log-dir
  --progress-file PLIK    Plik postępu Ralph loopa. Domyślnie: <log-dir>/progress.txt
  --no-progress-file      Wyłącz dołączanie pliku postępu do promptu
  --completion-promise T  Sigil kończący pętlę. Domyślnie: COMPLETE
  --permission-mode TRYB  Claude permission mode. Domyślnie: acceptEdits
  --output-format FORMAT  text, json albo stream-json. Domyślnie: stream-json
  --help                  Pokaż pomoc

Zmienne środowiskowe:
  PROGRESS_FILE           To samo co --progress-file
  DELAY_SECONDS           To samo co --delay
  MAX_RUNS                To samo co --max-runs
  CONTINUE_ON_ERROR       1 = kontynuuj po błędzie, 0 = przerwij
  WAIT_ON_LIMIT           1 = czekaj na reset limitu, 0 = nie czekaj
  WAIT_FALLBACK_SECONDS   To samo co --wait-fallback
  WAIT_BUFFER_SECONDS     To samo co --wait-buffer
  COMPLETION_PROMISE      To samo co --completion-promise
  PERMISSION_MODE         To samo co --permission-mode
  OUTPUT_FORMAT           To samo co --output-format
  LOG_DIR                 To samo co --log-dir
  LOG_FILE                To samo co --log-file
EOF
}

die() {
  echo "error: $*" >&2
  exit 1
}

is_non_negative_integer() {
  [[ "$1" =~ ^[0-9]+$ ]]
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

log() {
  local message="$1"
  printf '%s\n' "$message" | tee -a "$LOG_FILE"
}

normalize_path() {
  local target="$1"

  if [[ -d "$target" ]]; then
    (cd "$target" && pwd)
  else
    (cd "$(dirname "$target")" && printf '%s/%s\n' "$(pwd)" "$(basename "$target")")
  fi
}

prompt_reference_for_file() {
  local file="$1"
  local absolute

  absolute="$(normalize_path "$file")"

  if [[ "$absolute" == "$ROOT/"* ]]; then
    printf '%s' "${absolute#$ROOT/}"
  else
    printf '%s' "$absolute"
  fi
}

build_iteration_prompt() {
  local prompt_ref progress_ref progress_section=""

  prompt_ref="@$(prompt_reference_for_file "$PROMPT_FILE")"

  if [[ -n "$PROGRESS_FILE" ]]; then
    progress_ref="@$(prompt_reference_for_file "$PROGRESS_FILE")"
    progress_section=$'\n'"$progress_ref"
  fi

  cat <<EOF
$prompt_ref$progress_section

Jesteś uruchomiony w pętli Ralph.

W tej iteracji:
1. Przeczytaj prompt i plik postępu.
2. Wybierz dokładnie jeden najmniejszy następny krok, który realnie możesz domknąć teraz.
3. Wprowadź zmiany, uruchom odpowiednią weryfikację i zostaw repo w spójnym stanie.
4. Zaktualizuj plik postępu: co zostało zrobione, co jest następne, jakie są blokery.
5. Jeśli całość jest zakończona, wypisz dokładnie <promise>${COMPLETION_PROMISE}</promise>.
6. Jeśli potrzebujesz zgody człowieka, inputu, sekretu albo decyzji produktowej, wypisz dokładnie <approval-request>KRÓTKI POWÓD</approval-request> i zakończ iterację bez czekania na odpowiedź.
7. Nie zaczynaj drugiego taska ani drugiego większego kroku w tej samej iteracji.
EOF
}

looks_like_permission_prompt() {
  local output="$1"
  grep -Eiq '(requires approval|requires permission|permission required|approval required|do you want to allow|allow this action|cannot continue without approval|needs your approval)' <<< "$output"
}

contains_completion_promise() {
  local output="$1"
  grep -Fq "<promise>${COMPLETION_PROMISE}</promise>" <<< "$output"
}

contains_approval_request() {
  local output="$1"
  grep -Eiq '<approval-request>.*</approval-request>' <<< "$output"
}

format_stream_json_line() {
  local line="$1"
  local rendered

  if ! command -v jq >/dev/null 2>&1; then
    printf '%s\n' "$line"
    return 0
  fi

  rendered="$(jq -r '
    if .type == "system" and .subtype == "init" then
      "[session] model=" + (.model // "?") + " permission=" + (.permissionMode // "?")
    elif .type == "result" and (.result? != null) then
      .result
    elif .type == "assistant" and .message.content? then
      [
        .message.content[]?
        | if (.type // "") == "text" and (.text? != null) then
            .text
          elif (.type // "") == "tool_use" then
            "[tool] " + (.name // "unknown")
            + (
              if .input.command? then ": " + .input.command
              elif .input.file_path? then ": " + .input.file_path
              elif .input.path? then ": " + .input.path
              elif .input.pattern? then ": " + .input.pattern
              elif .input? then ": " + (.input | tojson)
              else ""
              end
            )
          else
            empty
          end
      ] | join("\n")
    elif .type == "user" and (.tool_use_result? != null) then
      if (.message.content[0]?.is_error // false) then
        "[tool error] " + .tool_use_result
      else
        empty
      end
    else
      empty
    end
  ' <<< "$line" 2>/dev/null || true)"

  if [[ -n "$rendered" ]]; then
    printf '%s\n' "$rendered"
  fi
}

capture_approval_output() {
  local tmp_output="$1"
  local attempt="$2"
  local artifact

  artifact="$LOG_DIR/approval-attempt-$(printf '%03d' "$attempt").jsonl"
  cp "$tmp_output" "$artifact"
  printf '%s\n' "$artifact"
}

extract_last_tool_use() {
  local input_file="$1"

  if ! command -v jq >/dev/null 2>&1; then
    return 0
  fi

  jq -r '
    select(.type == "assistant" and .message.content?)
    | .message.content[]?
    | select((.type // "") == "tool_use")
    | "[tool] " + (.name // "unknown")
      + (
        if .input.command? then ": " + .input.command
        elif .input.file_path? then ": " + .input.file_path
        elif .input.path? then ": " + .input.path
        elif .input.pattern? then ": " + .input.pattern
        elif .input? then ": " + (.input | tojson)
        else ""
        end
      )
  ' "$input_file" 2>/dev/null | tail -1
}

extract_permission_evidence() {
  local input_file="$1"

  grep -Eai '(requires approval|requires permission|permission required|approval required|do you want to allow|allow this action|cannot continue without approval|needs your approval)' "$input_file" | tail -5 || true
}

run_claude_iteration() {
  local prompt="$1"
  local tmp_output="$2"
  local -a cmd=(claude -p "$prompt" --permission-mode "$PERMISSION_MODE" --output-format "$OUTPUT_FORMAT")
  local exit_code formatted

  if [[ "$OUTPUT_FORMAT" == "stream-json" ]]; then
    cmd+=(--verbose --include-partial-messages)
  fi

  set +e
  if [[ "$OUTPUT_FORMAT" == "stream-json" ]]; then
    "${cmd[@]}" 2>&1 | while IFS= read -r line || [[ -n "$line" ]]; do
      printf '%s\n' "$line" >> "$tmp_output"
      formatted="$(format_stream_json_line "$line")"
      if [[ -n "$formatted" ]]; then
        printf '%s\n' "$formatted" | tee -a "$LOG_FILE"
      fi
    done
    exit_code=${PIPESTATUS[0]}
  else
    "${cmd[@]}" 2>&1 | tee -a "$LOG_FILE" "$tmp_output"
    exit_code=${PIPESTATUS[0]}
  fi
  set -e

  return "$exit_code"
}

parse_epoch() {
  local candidate="$1"
  date --date="$candidate" +%s 2>/dev/null
}

seconds_until_candidate() {
  local candidate="$1"
  local now epoch

  now="$(date +%s)"

  if epoch="$(parse_epoch "$candidate")"; then
    if [[ "$epoch" -gt "$now" ]]; then
      echo $((epoch - now + WAIT_BUFFER_SECONDS))
      return 0
    fi
  fi

  if epoch="$(parse_epoch "tomorrow $candidate")"; then
    if [[ "$epoch" -gt "$now" ]]; then
      echo $((epoch - now + WAIT_BUFFER_SECONDS))
      return 0
    fi
  fi

  return 1
}

extract_wait_seconds() {
  local output="$1"
  local line candidate

  while IFS= read -r line; do
    if [[ "$line" =~ [Rr]etry-?[[:space:]]?[Aa]fter[^0-9]*([0-9]+) ]]; then
      echo $((BASH_REMATCH[1] + WAIT_BUFFER_SECONDS))
      return 0
    fi
  done <<< "$output"

  while IFS= read -r line; do
    if [[ "$line" =~ [Rr]esets?([[:space:]]+at)?[[:space:]]+(.+) ]]; then
      candidate="${BASH_REMATCH[2]}"
      candidate="${candidate%% - continuing with extra usage*}"
      candidate="${candidate%%|*}"
      candidate="${candidate%%$'\r'*}"
      candidate="${candidate%%$'\n'*}"
      candidate="$(trim "$candidate")"
      candidate="${candidate%.}"
      candidate="${candidate%,}"

      if [[ -n "$candidate" ]] && seconds_until_candidate "$candidate" >/dev/null; then
        seconds_until_candidate "$candidate"
        return 0
      fi
    fi
  done <<< "$output"

  if grep -Eiq '(usage limit|rate limit|limit reached|429)' <<< "$output"; then
    echo "$WAIT_FALLBACK_SECONDS"
    return 0
  fi

  return 1
}

looks_like_limit_error() {
  local output="$1"
  grep -Eiq '(usage limit|rate limit|limit reached|retry-after|429|resets? at|resets? )' <<< "$output"
}

sleep_until_retry() {
  local total_seconds="$1"
  local reason="$2"
  local remaining chunk resume_at

  remaining="$total_seconds"
  resume_at="$(date --date="+${total_seconds} seconds" '+%Y-%m-%d %H:%M:%S')"

  log "$reason"
  log "Wznowienie nie wcześniej niż: $resume_at"

  while [[ "$remaining" -gt 0 ]]; do
    if [[ "$stop_requested" -eq 1 ]]; then
      return 1
    fi

    chunk=60
    if [[ "$remaining" -lt "$chunk" ]]; then
      chunk="$remaining"
    fi

    sleep "$chunk" || true
    remaining=$((remaining - chunk))
  done

  return 0
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --prompt)
      [[ $# -ge 2 ]] || die "brakuje wartości dla --prompt"
      PROMPT_FILE="$2"
      shift 2
      ;;
    --delay)
      [[ $# -ge 2 ]] || die "brakuje wartości dla --delay"
      DELAY_SECONDS="$2"
      shift 2
      ;;
    --max-runs)
      [[ $# -ge 2 ]] || die "brakuje wartości dla --max-runs"
      MAX_RUNS="$2"
      shift 2
      ;;
    --continue-on-error)
      CONTINUE_ON_ERROR=1
      shift
      ;;
    --no-wait-on-limit)
      WAIT_ON_LIMIT=0
      shift
      ;;
    --wait-fallback)
      [[ $# -ge 2 ]] || die "brakuje wartości dla --wait-fallback"
      WAIT_FALLBACK_SECONDS="$2"
      shift 2
      ;;
    --wait-buffer)
      [[ $# -ge 2 ]] || die "brakuje wartości dla --wait-buffer"
      WAIT_BUFFER_SECONDS="$2"
      shift 2
      ;;
    --log-dir)
      [[ $# -ge 2 ]] || die "brakuje wartości dla --log-dir"
      LOG_DIR="$2"
      shift 2
      ;;
    --log-file)
      [[ $# -ge 2 ]] || die "brakuje wartości dla --log-file"
      LOG_FILE="$2"
      shift 2
      ;;
    --progress-file)
      [[ $# -ge 2 ]] || die "brakuje wartości dla --progress-file"
      PROGRESS_FILE="$2"
      PROGRESS_FILE_DISABLED=0
      shift 2
      ;;
    --no-progress-file)
      PROGRESS_FILE=""
      PROGRESS_FILE_DISABLED=1
      shift
      ;;
    --completion-promise)
      [[ $# -ge 2 ]] || die "brakuje wartości dla --completion-promise"
      COMPLETION_PROMISE="$2"
      shift 2
      ;;
    --permission-mode)
      [[ $# -ge 2 ]] || die "brakuje wartości dla --permission-mode"
      PERMISSION_MODE="$2"
      shift 2
      ;;
    --output-format)
      [[ $# -ge 2 ]] || die "brakuje wartości dla --output-format"
      OUTPUT_FORMAT="$2"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      die "nieznana opcja: $1"
      ;;
  esac
done

[[ -f "$PROMPT_FILE" ]] || die "nie znaleziono pliku promptu: $PROMPT_FILE"
is_non_negative_integer "$DELAY_SECONDS" || die "--delay musi być liczbą >= 0"
is_non_negative_integer "$MAX_RUNS" || die "--max-runs musi być liczbą >= 0"
is_non_negative_integer "$WAIT_FALLBACK_SECONDS" || die "--wait-fallback musi być liczbą >= 0"
is_non_negative_integer "$WAIT_BUFFER_SECONDS" || die "--wait-buffer musi być liczbą >= 0"
[[ "$CONTINUE_ON_ERROR" == "0" || "$CONTINUE_ON_ERROR" == "1" ]] || die "CONTINUE_ON_ERROR musi być równe 0 albo 1"
[[ "$WAIT_ON_LIMIT" == "0" || "$WAIT_ON_LIMIT" == "1" ]] || die "WAIT_ON_LIMIT musi być równe 0 albo 1"
[[ "$OUTPUT_FORMAT" == "text" || "$OUTPUT_FORMAT" == "json" || "$OUTPUT_FORMAT" == "stream-json" ]] || die "--output-format musi być jednym z: text, json, stream-json"
[[ -n "$COMPLETION_PROMISE" ]] || die "--completion-promise nie może być pusty"

if [[ -z "$LOG_FILE" ]]; then
  LOG_FILE="$LOG_DIR/$(date '+%Y%m%d-%H%M%S').log"
fi

mkdir -p "$(dirname "$LOG_FILE")"
touch "$LOG_FILE"

if [[ "$PROGRESS_FILE_DISABLED" -eq 0 && -z "$PROGRESS_FILE" ]]; then
  PROGRESS_FILE="$LOG_DIR/progress.txt"
fi

if [[ -n "$PROGRESS_FILE" ]]; then
  mkdir -p "$(dirname "$PROGRESS_FILE")"
  touch "$PROGRESS_FILE"
fi

stop_requested=0
attempt_count=0
completed_runs=0

on_interrupt() {
  stop_requested=1
  printf '\n' | tee -a "$LOG_FILE" >/dev/null
  log "Odebrano sygnał przerwania. Zatrzymuję pętlę po bieżącej operacji..."
}

trap on_interrupt INT TERM

log "Start runnera. Log file: $LOG_FILE"
log "Prompt: $PROMPT_FILE"
if [[ -n "$PROGRESS_FILE" ]]; then
  log "Progress file: $PROGRESS_FILE"
else
  log "Progress file: <disabled>"
fi
log "Permission mode: $PERMISSION_MODE"
log "Output format: $OUTPUT_FORMAT"
log "Completion promise: <promise>${COMPLETION_PROMISE}</promise>"

while :; do
  if [[ "$MAX_RUNS" -gt 0 && "$completed_runs" -ge "$MAX_RUNS" ]]; then
    log "Osiągnięto limit udanych iteracji: $MAX_RUNS"
    break
  fi

  if [[ "$stop_requested" -eq 1 ]]; then
    break
  fi

  attempt_count=$((attempt_count + 1))
  started_at="$(date '+%Y-%m-%d %H:%M:%S')"
  prompt_body="$(<"$PROMPT_FILE")"

  if [[ -z "$prompt_body" ]]; then
    die "plik promptu jest pusty: $PROMPT_FILE"
  fi

  prompt="$(build_iteration_prompt)"

  log "[$started_at] Start próby #$attempt_count, celowana udana iteracja #$((completed_runs + 1)) z promptu: $PROMPT_FILE"

  tmp_output="$(mktemp)"
  if run_claude_iteration "$prompt" "$tmp_output"; then
    exit_code=0
  else
    exit_code=$?
  fi

  finished_at="$(date '+%Y-%m-%d %H:%M:%S')"
  log "[$finished_at] Koniec próby #$attempt_count, exit code: $exit_code"

  output="$(<"$tmp_output")"

  if contains_approval_request "$output" || looks_like_permission_prompt "$output"; then
    local approval_output_file last_tool approval_evidence
    approval_output_file="$(capture_approval_output "$tmp_output" "$attempt_count")"
    last_tool="$(extract_last_tool_use "$tmp_output")"
    approval_evidence="$(extract_permission_evidence "$tmp_output")"
    rm -f "$tmp_output"

    log "Wykryto prośbę o zgodę albo approval prompt. Ralph loop zatrzymuje się zamiast wisieć bez końca."
    log "Surowy output iteracji zapisany do: $approval_output_file"
    if [[ -n "$last_tool" ]]; then
      log "Ostatni tool przed stopem: $last_tool"
    fi
    if [[ -n "$approval_evidence" ]]; then
      log "Dopasowane linie z outputu:"
      while IFS= read -r line; do
        [[ -n "$line" ]] || continue
        log "  $line"
      done <<< "$approval_evidence"
    fi
    log "Rozwiązanie: poszerz allowlistę w .claude/settings.json albo uruchom z innym --permission-mode dla tego środowiska."
    exit 2
  fi

  rm -f "$tmp_output"

  if [[ "$exit_code" -eq 0 ]] && contains_completion_promise "$output"; then
    completed_runs=$((completed_runs + 1))
    log "Claude zgłosił zakończenie pracy przez completion promise. Kończę pętlę."
    break
  fi

  if [[ "$exit_code" -eq 0 ]]; then
    completed_runs=$((completed_runs + 1))

    if [[ "$stop_requested" -eq 1 ]]; then
      break
    fi

    if [[ "$DELAY_SECONDS" -gt 0 ]]; then
      log "Czekam ${DELAY_SECONDS}s przed następną udaną iteracją..."
      sleep_until_retry "$DELAY_SECONDS" "Pauza między iteracjami..."
    fi

    continue
  fi

  if [[ "$WAIT_ON_LIMIT" -eq 1 ]] && looks_like_limit_error "$output"; then
    if wait_seconds="$(extract_wait_seconds "$output")"; then
      if sleep_until_retry "$wait_seconds" "Wykryto limit użycia Claude. Czekam na reset i ponawiam tę samą iterację..."; then
        continue
      fi
      break
    fi
  fi

  if [[ "$CONTINUE_ON_ERROR" -eq 1 ]]; then
    log "Komenda zakończyła się błędem, ale \`--continue-on-error\` jest aktywne. Przechodzę do następnej próby."
    continue
  fi

  log "Przerywam po błędzie. Ustaw --continue-on-error, jeśli pętla ma iść dalej."
  exit "$exit_code"
done

log "Pętla zakończona. Udane iteracje: $completed_runs, wszystkie próby: $attempt_count."
